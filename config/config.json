{
  "vision": {
    "dummy_mode": false,
    "dummy_interval_sec": 3,

    "mode": "yolo",
    "yolo_model_path": "models/best.pt",
    "yolo_conf": 0.4,
    "yolo_iou": 0.4,
    "yolo_imgsz": 416,
    "min_conf": 0.40,
    "inspect_frames": 5,
    "inspect_window_sec": 1.0,

    "yolo_class_map": {
      "IC":      { "part": "IC",            "verdict": "PASS" },
      "CAP":     { "part": "Capacitor",     "verdict": "PASS" },
      "HS":      { "part": "Heatsink",      "verdict": "PASS" },
      "TB":      { "part": "TerminalBlock", "verdict": "PASS" },
      "Broken":  { "verdict": "REJECT" },
      "Dented":  { "verdict": "REJECT" },
      "Pinbent": { "verdict": "REJECT" }
    },

    "yolo_class_index": {
      "0": "Broken", "1": "CAP", "2": "Dented", "3": "HS",
      "4": "IC", "5": "Pinbent", "6": "TB"
    },
    "defect_iou_threshold": 0.3,
    "defect_min_conf": 0.35,

    "pin_inspector": {
      "canny_low": 50,
      "canny_high": 150,
      "blur_ksize": 5,
      "expected_pin_count": { "IC": 14, "TerminalBlock": 6, "Heatsink": 0, "Capacitor": 2 },
      "pin_gap_tolerance_pct": 30,
      "tip_y_tolerance_px": 10
    }
  },

  "cameras": {
    "top":  {
      "index": 0, "width": 1280, "height": 720, "fps": 60,
      "fourcc": "MJPG",
      "square_crop": true,
      "controls": {
        "_comment": "형광등(현재): 벨트 1.5cm/s로 느려 노출 길어도 블러 미미. -5(~31ms)로 밝게. 더 어두우면 -4(62ms). LED 추가 후: exposure -9~-10 으로 낮추고 gain 0~10 으로 줄일 것.",
        "auto_exposure": 0.25,
        "exposure": -5,
        "gain": 40,
        "auto_wb": 0,
        "wb_temperature": 4500
      }
    },
    "side": { "index": 1 }
  },

  "stream": {
    "dir": "data/stream",
    "jpeg_quality": 70,
    "fps": 10
  },

  "conveyor": {
    "speed_cm_per_s": 1.5,
    "camera_to_gate1_cm": 30,
    "camera_to_gate2_cm": 45,
    "gate_delay_offset_sec": -4.5
  },

  "serial": {
    "port": "COM5",
    "baudrate": 115200,
    "dummy_mode": false
  },

  "gates": {
    "1": { "push_angle": 90, "return_angle": 0, "delay_ms": 500, "delay_sec": 20.0 },
    "2": { "push_angle": 90, "return_angle": 0, "delay_ms": 500, "delay_sec": 30.0 },
    "pusher_hold_sec": 0.3
  },

  "sensor": {
    "debounce_sec": 0.5,
    "trigger_to_capture_sec": 6.0
  },

  "robot": {
    "host": "192.168.0.47",
    "port": 9000,
    "_port_note": "pymycobot 공식 소켓 서버 포트(9000) — 기존 커스텀 RPi4 JSON 서버(9002) 아님. real 전환 시 Pi에서 공식 소켓 서버 실행 + 'pip install pymycobot' 필요. mock 은 mock.robot.port(9002, MockMyCobot) 사용.",
    "speed": 80,
    "dummy_mode": true,
    "gripper_open": 100,
    "gripper_close": 30,
    "pickup_angles": [0, 0, 0, 0, 0, 0],
    "lift_angles":   [0, 0, 0, 0, 0, 0],
    "place_angles":  [0, 0, 0, 0, 0, 0],
    "home_angles":   [0, 0, 0, 0, 0, 0],
    "_angles_note": "4개 자세는 티칭으로 채울 것 — robot.dummy_mode=false 로 두고 get_angles() 기록 (Phase2 Step6 dense teach 10~15점). 현재 0 은 미티칭 플레이스홀더.",
    "joint_limits": { "j2_min_deg": -120, "j3_min_deg": -120 }
  },

  "agv": {
    "count": 2,
    "speed": 50,
    "dummy_mode": true,
    "nodes": {
      "start":     "N1",
      "warehouse": "WAREHOUSE"
    }
  },

  "recipe": {
    "parts": ["IC칩", "터미널블록", "방열판", "커패시터"]
  },

  "mock": {
    "esp32": { "host": "localhost", "port": 9001 },
    "robot": { "host": "localhost", "port": 9002 },
    "agv":   { "host": "localhost", "port": 9003 }
  },

  "mqtt": {
    "broker": "localhost",
    "port": 1883,
    "topics": {
      "inspection":   "visipick/inspection",
      "robot_cmd":    "visipick/robot/cmd",
      "agv_status":   "visipick/agv/{id}/status",
      "system_event": "visipick/system/event",
      "gate_cmd":     "visipick/gate/cmd"
    }
  },

  "database": {
    "path": "C:\\VisiPick\\data\\visipick.db",
    "retention_days_inspection": 30,
    "retention_days_events": 7
  },

  "system": {
    "heartbeat_interval_sec": 2,
    "log_dir": "logs",
    "demo_cycles": 50,
    "autorun_fsm": false,
    "_autorun_fsm_note": "true 면 api_server 가 startup 훅으로 FSM 까지 동반 기동(로드맵 §0.1). 기본 false — FSM 은 보통 'python src/core/state_machine.py' 별도 프로세스로 운용."
  }
}
